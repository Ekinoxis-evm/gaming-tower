# ── Wallet ────────────────────────────────────────────────────────────────────
PRIVATE_KEY=your_private_key_here

# ── Networks ──────────────────────────────────────────────────────────────────
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
BASESCAN_API_KEY=your_basescan_api_key_here

# ── Shared ────────────────────────────────────────────────────────────────────
DEFAULT_TREASURY=0xYourTreasuryAddress
RESOLVER_ADDRESS=0xYourResolverAddress

# ── VaultFactory: accepted staking tokens ─────────────────────────────────────
# ACCEPTED_TOKEN_1 is required. TOKEN_2 and TOKEN_3 are optional.
# 1UP → 18 decimals | USDC → 6 decimals | EUROC → 18 decimals
ACCEPTED_TOKEN_1=0x05cb1e3ba6102b097c0ad913c8b82ac76e7df73f    # 1UP — Base Sepolia
# ACCEPTED_TOKEN_2=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913  # USDC — Base Mainnet
# ACCEPTED_TOKEN_3=0x60a3E35Cc302bFA44Cb288Bc5a4F316Fdb1adb42  # EUROC — Base Mainnet

# ── Deployed addresses ────────────────────────────────────────────────────────
# Fill in after each deploy step. IDENTITY_NFT is the first city collection
# deployed by the admin from the frontend via IdentityNFTFactory.deployCollection().

IDENTITY_NFT_FACTORY=0xDeployedIdentityNFTFactory  # deploy.sh --step identity-factory
IDENTITY_NFT=0xFirstCityCollection                  # set after admin creates first city from frontend
VAULT_FACTORY_ADDRESS=0xDeployedVaultFactory        # deploy.sh --step vault-factory
FACTORY_ADDRESS=0xDeployedCourseFactory             # deploy.sh --step course-factory
